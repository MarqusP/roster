rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared roster + chapter settings: readable/writable by any signed-in
    // member (Google sign-in required by the app).
    match /alumni/{docId} {
      allow read, write: if request.auth != null;
    }
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
    // Each member's own outreach progress ("My Info" + status/notes/history)
    // -- only that member can read or write their own doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
