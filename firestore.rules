rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Open read/write so any chapter member with the app URL can use it --
    // no login system. Fine for a small, trusted group. If you want more
    // protection later, add Firebase Authentication and restrict these
    // rules to signed-in users (e.g. an allowlist of chapter emails).
    match /alumni/{docId} {
      allow read, write: if true;
    }
    match /settings/{docId} {
      allow read, write: if true;
    }
  }
}
