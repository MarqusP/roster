rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared roster: any signed-in member can read, add, and edit entries.
    // Deleting entries (including the chapter admin's bulk "clear all roster"
    // action) is destructive and shared, so it's restricted to admins --
    // members listed in /admins -- rather than any signed-in user.
    match /alumni/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
    // Admin roster -- doc ID is the member's uid. Membership is granted
    // manually (Firebase console), never by clients: a signed-in member may
    // only read their own doc (to check "am I an admin?"), and no client may
    // write to this collection at all.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    // Each member's own outreach progress ("My Info" + status/notes/history)
    // -- only that member can read or write their own doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Metadata for scheduled ("send later") emails -- the actual send is
    // driven by Upstash QStash, not by reading this collection. It exists
    // only so the app can show/cancel a member's own pending scheduled sends.
    match /scheduledEmails/{id} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      // Narrow and intentionally auth-agnostic: api/send-scheduled-email.js
      // is invoked by QStash (no Firebase session) and needs to report
      // delivery status without a service account. Limited to exactly these
      // three fields -- worst case someone who knows a doc ID (a random
      // UUID) flips its status cosmetically; they can't read or redirect
      // the email itself. Ownership for cancel is enforced in
      // api/cancel-scheduled-email.js before this rule is ever reached.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "sentAt", "error"]);
      allow delete: if false;
    }
  }
}
